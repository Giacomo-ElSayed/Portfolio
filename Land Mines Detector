    "# ================================\n",
    "# IMPLEMENTAZIONE MODELLI\n",
    "# ================================\n",
    "# F1 e recall sono le metriche principali per il task binario, mentre F1 macro è la metrica principale per il task multiclasse.\n",
    "# Con F1 i modelli performano meglio rispetto a recall, ma per il task binario si cerca di minimizzare i falsi negativi, quindi si utilizza recall come metrica principale.\n",
    "def knn(X_train, y_train, X_test, y_test, task):\n",
    "\n",
    "    # Algoritmo KNN per classificazione binaria e multiclasse\n",
    "    # GridSearchCV per ottimizzare i parametri\n",
    "    # StratifiedKFold per la validazione incrociata\n",
    "    # Scoring basato su recall per task binario per minimizzare i Falsi Negativi\n",
    "    # Scoring basato su F1 macro per task multiclasse per bilanciare precisione e recall\n",
    "    \n",
    "    knn = KNeighborsClassifier()\n",
    "    cv_folds = 10\n",
    "\n",
    "    if task == 'binary':\n",
    "        param_grid = {\n",
    "            'n_neighbors': [3, 5, 7, 10, 15],\n",
    "            'weights': ['uniform', 'distance'],\n",
    "            'metric': ['euclidean', 'manhattan', 'minkowski'],\n",
    "        }\n",
    "        scoring = 'recall'\n",
    "        \n",
    "    else:\n",
    "        param_grid = {\n",
    "            'n_neighbors': [3, 5, 7, 11, 15, 21],\n",
    "            'weights': ['uniform', 'distance'],\n",
    "            'metric': ['euclidean', 'manhattan', 'minkowski'],\n",
    "        }\n",
    "        scoring = 'f1_macro'\n",
    "        \n",
    "\n",
    "    # --- GridSearchCV ---\n",
    "    grid = GridSearchCV(\n",
    "        estimator = knn,\n",
    "        param_grid=param_grid,\n",
    "        cv=StratifiedKFold(n_splits=cv_folds, shuffle=True, random_state=42),\n",
    "        scoring=scoring,\n",
    "    )\n",
    "\n",
    "    grid.fit(X_train, y_train)\n",
    "    best_model = grid.best_estimator_\n",
    "    print(f\"Best parameters: {grid.best_params_}\")\n",
    "    print(f\"Best CV score: {grid.best_score_:.4f}\")\n",
    "\n",
    "    results = evaluate_model(best_model, X_train, y_train, X_test, y_test, task_type='binary' if task == 'binary' else 'multiclass')\n",
