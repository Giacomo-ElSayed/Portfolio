    "# ==================================\n",
    "# MAIN PIPELINE - ESECUZIONE MODELLI\n",
    "# ==================================\n",
    "# Obbiettivi:\n",
    "# 1. Eseguire i KNN con solo le features Voltage Height e Soil, senza encoding standardizzazione e oversampling\n",
    "# 2. Eseguire i KNN con oversampling con le features Voltage Height e Soil, senza encoding e standardizzazione\n",
    "# 3. Eseguire Logistic Regression con feature aggiuntive\n",
    "# 4. Eseguire ANN con encoding e standardizzazione\n",
    "# 5. Eseguire ANN con encoding, standardizzazione e feature aggiunte\n",
    "# 6. Eseguire ANN con encoding, standardizzazione, feature aggiunte e oversampling\n",
    "\n",
    "def main():\n",
    "\n",
    "    # ===============================\n",
    "    # DETECTION TASK (BINARIA)\n",
    "    # ===============================\n",
    "    print('=== DETECTION TASK ===')\n",
    "    print('Confronto tra KNN e ANN con dataset sbilanciato, bilanciato e con feature aggiuntive')\n",
    "\n",
    "    # Eseguire KNN/KNN GENETICO con dataset non processato\n",
    "    print(\"\\n Esecuzione KNN con dataset non processato (features base)...\")\n",
    "    knn(X_train_knn_basic_binary, y_train_knn_basic_binary, X_test_knn_basic_binary, y_test_knn_basic_binary, 'binary')\n",
    "    print(\"\\n Esecuzione KNN GENETICO con dataset non processato (features base)...\")\n",
    "    knn_genetico(X_train_knn_basic_binary, y_train_knn_basic_binary, X_test_knn_basic_binary, y_test_knn_basic_binary, 'binary')\n",
    "\n",
    "    # Eseguire KNN/KNN GENETICO con oversampling\n",
    "    print(\"\\n Esecuzione KNN con oversampling (features base)...\")\n",
    "    knn(X_train_knn_oversampled_binary, y_train_knn_oversampled_binary, X_test_knn_oversampled_binary, y_test_knn_oversampled_binary, 'binary')\n",
    "    print(\"\\n Esecuzione KNN GENETICO con oversampling (features base)...\")\n",
    "    knn_genetico(X_train_knn_oversampled_binary, y_train_knn_oversampled_binary, X_test_knn_oversampled_binary, y_test_knn_oversampled_binary, 'binary')\n",
    "    \n",
    "    # Eseguire Logistic Regression con feature aggiuntive\n",
    "    print(\"\\n Esecuzione Linear Regression con feature aggiuntive...\")\n",
    "    logistic_regression(X_train_ann_engineered_binary, y_train_ann_engineered_binary, X_test_ann_engineered_binary, y_test_ann_engineered_binary,'binary')\n",
    "    \n",
    "    # Eseguire ANN con encoding e standardizzazione\n",
    "    print(\"\\n Esecuzione ANN con encoding e standardizzazione...\")\n",
    "    ann(X_train_ann_basic_binary, y_train_ann_basic_binary, X_test_ann_basic_binary, y_test_ann_basic_binary, 'binary')\n",
    "\n",
    "    # Eseguire ANN con feature aggiuntive\n",
    "    print(\"\\n Esecuzione ANN con feature aggiuntive...\")\n",
    "    ann(X_train_ann_engineered_binary, y_train_ann_engineered_binary, X_test_ann_engineered_binary, y_test_ann_engineered_binary, 'binary')\n",
    "\n",
    "    # Eseguire ANN completo (encoding + standardizzazione + feature aggiuntive + oversampling)\n",
    "    print(\"\\n Esecuzione ANN completo (con oversampling)...\")\n",
    "    ann(X_train_ann_full_oversampled_binary, y_train_ann_full_oversampled_binary, X_test_ann_full_binary, y_test_ann_full_binary, 'binary')\n",
    "\n",
    "    # ===============================\n",
    "    # CLASSIFICATION TASK (MULTICLASSE)\n",
    "    # ===============================\n",
    "    print('\\n=== CLASSIFICATION TASK ===')\n",
    "\n",
    "    # Eseguire KNN GENETICO con dataset non processato\n",
    "    print(\"\\n Esecuzione KNN GENETICO con dataset non processato (features base)...\")\n",
    "    knn_genetico(X_train_knn_basic_multiclass, y_train_knn_basic_multiclass, X_test_knn_basic_multiclass, y_test_knn_basic_multiclass, 'multiclass')\n",
    "    \n",
    "    # Eseguire KNN GENETICO con oversampling\n",
    "    print(\"\\n Esecuzione KNN genetico con oversampling (features base)...\")\n",
    "    knn_genetico(X_train_knn_oversampled_multiclass, y_train_knn_oversampled_multiclass, X_test_knn_oversampled_multiclass, y_test_knn_oversampled_multiclass, 'multiclass')\n",
    "     \n",
    "    # Eseguire Logistic Regression con feature aggiuntive\n",
    "    print(\"\\n Esecuzione Logistic Regression con feature aggiuntive...\")\n",
    "    logistic_regression(X_train_ann_engineered_multiclass, y_train_ann_engineered_multiclass, X_test_ann_engineered_multiclass, y_test_ann_engineered_multiclass, 'multiclass')\n",
    "\n",
    "    # Eseguire ANN con encoding e standardizzazione\n",
    "    print(\"\\n Esecuzione ANN con encoding e standardizzazione...\")\n",
    "    ann(X_train_ann_basic_multiclass, y_train_ann_basic_multiclass, X_test_ann_basic_multiclass, y_test_ann_basic_multiclass, 'multiclass')\n",
    "    \n",
    "    # Eseguire ANN con feature aggiuntive\n",
    "    print(\"\\n Esecuzione ANN con feature aggiuntive...\")\n",
    "    ann(X_train_ann_engineered_multiclass, y_train_ann_engineered_multiclass, X_test_ann_engineered_multiclass, y_test_ann_engineered_multiclass, 'multiclass')\n",
    "    \n",
    "    # Eseguire ANN completo (encoding + standardizzazione + feature aggiuntive + oversampling)\n",
    "    print(\"\\n Esecuzione ANN completo (con oversampling)...\")\n",
    "    ann(X_train_ann_full_oversampled_multiclass, y_train_ann_full_oversampled_multiclass, X_test_ann_full_multiclass, y_test_ann_full_multiclass, 'multiclass')\n",
    "\n",
