    "        }\n",
    "        cv_folds = 10\n",
    "        scoring = 'f1'\n",
    "    \n",
    "    grid = GridSearchCV(\n",
    "        MLPClassifier(\n",
    "            solver='adam',\n",
    "            learning_rate='adaptive',\n",
    "            max_iter=300,  # Increased iterations\n",
    "            early_stopping=True,\n",
    "            validation_fraction=0.1,\n",
    "            n_iter_no_change=15,  # More patience\n",
    "            random_state=42,\n",
    "        ),\n",
    "        param_grid=param_grid,\n",
    "        cv=StratifiedKFold(n_splits=cv_folds, shuffle=True, random_state=42),\n",
    "        scoring=scoring,\n",
    "    )\n",
    "    \n",
    "    grid.fit(X_train, y_train)\n",
    "    best_model = grid.best_estimator_\n",
    "    \n",
    "    print(f\"Best parameters: {grid.best_params_}\")\n",
    "    print(f\"Best CV score: {grid.best_score_:.4f}\")\n",
    "    \n",
    "    results = evaluate_model(best_model, X_train, y_train, X_test, y_test, task_type='binary' if task == 'binary' else 'multiclass')\n",
    "    \n",
    "    return best_model, results\n",
    "def knn_genetico(X_train, y_train, X_test, y_test, task):\n",
    "\n",
    "    # Algoritmo KNN con Genetic Algorithm per ottimizzazione dei pesi delle feature similmente al paper di riferimento\n",
    "    # Utilizzo di StratifiedKFold per la validazione incrociata\n",
    "    \n",
    "    # Parametri principali\n",
    "    pop_size = 50\n",
    "    generations = 100\n",
    "    mutation_rate = 0.5\n",
    "    elite_size = 5\n",
    "    \n",
    "    # Conversione in array numpy se necessario\n",
    "    X_values = X_train.values if hasattr(X_train, 'values') else np.array(X_train)\n",
    "    y_values = y_train.values if hasattr(y_train, 'values') else np.array(y_train)\n",
    "    X_test_values = X_test.values if hasattr(X_test, 'values') else np.array(X_test)\n",
    "    y_test_values = y_test.values if hasattr(y_test, 'values') else np.array(y_test)\n",
    "    \n",
    "    # Numero di features da pesare\n",
    "    num_features = X_values.shape[1]\n",
    "    \n",
    "    # Inizializzazione della popolazione randomicamente\n",
    "    population = [np.random.uniform(0.1, 2.0, size=num_features) for _ in range(pop_size)]\n",
    "    best_weights = None\n",
    "    best_fitness = -np.inf\n",
    "    \n",
    "    # Inizializzazione delle liste per tracciare l'evoluzione della fitness\n",
    "    fitness_history = []\n",
    "    best_fitness_history = []\n",
    "    \n",
    "    # Ciclo principale del Genetic Algorithm su tutte le generazioni\n",
    "    for gen in range(generations):\n",
    "        fitness_scores = []\n",
    "        # Calcolo della fitness per ogni individuo nella popolazione\n",
    "        for individual in population:\n",
    "            X_weighted = X_values * individual\n",
    "            \n",
    "            cv = StratifiedKFold(n_splits=10, shuffle=True, random_state=42)\n",
    "            scores = []\n",
    "            # Validazione incrociata per calcolare la fitness dell'individuo\n",
    "            for train_idx, val_idx in cv.split(X_weighted, y_values):\n",
    "                X_cv_train, X_cv_val = X_weighted[train_idx], X_weighted[val_idx]\n",
    "                y_cv_train, y_cv_val = y_values[train_idx], y_values[val_idx]\n",
    "                #KNN\n",
    "                model = KNeighborsClassifier(n_neighbors=5, weights='distance')\n",
    "                model.fit(X_cv_train, y_cv_train)\n",
    "                y_pred = model.predict(X_cv_val)\n",
    "                \n",
    "                if task == 'binary':\n",
    "                    score = recall_score(y_cv_val, y_pred) # fitness su recall per binary\n",
    "                else:\n",
    "                    score = f1_score(y_cv_val, y_pred, average='macro') # fitness su F1 Macro per multiclass\n",
    "                scores.append(score) #salvataggio score nella lista scores\n",
    "            \n",
    "            fitness = np.mean(scores) # fitness come media degli score di validazione dell'individuo\n",
    "            fitness_scores.append(fitness) # salvataggio della fitness dell'individuo nella lista delle fitness della generazione corrente\n",
    "        \n",
    "        # Tracking delle statistiche di fitness della generazione\n",
    "        avg_fitness = np.mean(fitness_scores)\n",
    "        max_fitness = np.max(fitness_scores)\n",
    "        fitness_history.append(avg_fitness) # salvataggio media fitness\n",
    "        best_fitness_history.append(max_fitness) # salvataggio max fitness\n",
    "        \n",
    "        # Update migliori individui\n",
    "        best_idx = np.argmax(fitness_scores)\n",
    "        if fitness_scores[best_idx] > best_fitness:\n",
    "            best_fitness = fitness_scores[best_idx]\n",
    "            best_weights = population[best_idx].copy() # salvataggio dei migliori pesi trovati\n",
    "        \n",
    "        # Elitismo e riproduzione\n",
    "        elite_indices = np.argsort(fitness_scores)[-elite_size:]\n",
    "        elite_population = [population[i].copy() for i in elite_indices]\n",
    "        new_population = elite_population.copy()\n",
    "        \n",
    "        # Generazione di nuovi individui tramite crossover, mutazione e mantenimento degli elitari\n",
    "        while len(new_population) < pop_size:\n",
    "            adjusted_fitness = np.array(fitness_scores) - min(fitness_scores) + 1e-6\n",
    "            parents = random.choices(population, weights=adjusted_fitness, k=2)\n",
    "\n",
    "            # Crossover tramite un coefficente random alpha tra i genitori\n",
    "            alpha = random.random()\n",
    "            child = alpha * parents[0] + (1 - alpha) * parents[1]\n",
    "            \n",
    "            # Mutazione con probabilità mutation_rate\n",
    "            if random.random() < mutation_rate:\n",
    "                mutation_strength = 0.1 * (1 - gen/generations)\n",
    "                mutation_indices = np.random.choice(num_features, \n",
    "                                                  size=max(1, int(num_features * 0.3)), \n",
    "                                                  replace=False)\n",
    "                for idx in mutation_indices:\n",
    "                    child[idx] += np.random.normal(0, mutation_strength)\n",
    "                child = np.clip(child, 0.1, 2.0)\n",
    "            \n",
    "            new_population.append(child) # salvataggio del nuovo individuo nella popolazione\n",
    "        \n",
    "        population = new_population # aggiornamento della popolazione con i nuovi individui generati\n",
    "    \n",
    "    print(f\"Final best fitness: {best_fitness:.4f}\")\n",
    "    \n",
    "    # Plot dell'evoluzione della fitness\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(15, 4))\n",
    "    axes[0].plot(range(generations), fitness_history, label='Average Fitness', color='blue')\n",
    "    axes[0].plot(range(generations), best_fitness_history, label='Best Fitness', color='red')\n",
    "    axes[0].set_xlabel('Generation')\n",
    "    axes[0].set_ylabel('Fitness (F1 Score)')\n",
    "    axes[0].set_title('Genetic Algorithm Evolution - Fitness')\n",
    "    axes[0].legend()\n",
    "    axes[0].grid(True, alpha=0.3)\n",
    "    \n",
    "    feature_names = [f'Feature_{i}' for i in range(num_features)]\n",
    "    axes[1].bar(feature_names, best_weights, color='purple', alpha=0.7)\n",
    "    axes[1].set_xlabel('Features')\n",
    "    axes[1].set_ylabel('Weight')\n",
    "    axes[1].set_title('Best Feature Weights')\n",
    "    axes[1].tick_params(axis='x', rotation=45)\n",
    "    axes[1].grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    # Modello finale con i migliori pesi\n",
    "    X_train_weighted = X_values * best_weights\n",
    "    X_test_weighted = X_test_values * best_weights\n",
    "    knn(X_train_weighted, y_values, X_test_weighted, y_test_values, task=task)\n",
    "def logistic_regression(X_train, y_train, X_test, y_test, task):\n",
    "  \n",
    "    # Algoritmo di regressione logistica per classificazione binaria e multiclass basato su One-vs-Rest\n",
    "\n",
    "    if task == 'binary':\n",
    "        param_grid = {\n",
    "            'C': np.logspace(-4, 4, 9),\n",
    "            'penalty': ['l1', 'l2'],\n",
    "            'solver': ['liblinear', 'saga'],\n",
    "            'class_weight': [None, 'balanced']\n",
    "        }\n",
    "        \n",
    "        model = LogisticRegression(max_iter=1000, random_state=42)\n",
    "        \n",
    "    else:\n",
    "       \n",
    "        base_estimator = LogisticRegression(\n",
    "            max_iter=1000,\n",
    "            random_state=42,\n",
    "            multi_class='ovr'  #One-vs-Rest\n",
    "        )\n",
    "        \n",
    "        # Parametri per il grid search\n",
    "        param_grid = {\n",
    "            'estimator__C': np.logspace(-4, 4, 9),\n",
    "            'estimator__penalty': ['l1', 'l2'],\n",
    "            'estimator__solver': ['liblinear', 'saga'],\n",
    "            'estimator__class_weight': [None, 'balanced']\n",
    "        }\n",
    "        \n",
    "        # OneVsRestClassifier\n",
    "       \n",
    "        model = OneVsRestClassifier(estimator=base_estimator)\n",
    "    \n",
    "    # Grid search\n",
    "    grid = GridSearchCV(\n",
    "        estimator=model,\n",
    "        param_grid=param_grid,\n",
    "        cv=StratifiedKFold(n_splits=5, shuffle=True, random_state=42),\n",
    "        scoring='f1_weighted' if task == 'multiclass' else 'f1',\n",
    "    )\n",
    "    \n",
    "    grid.fit(X_train, y_train)\n",
    "    best_model = grid.best_estimator_\n",
    "    \n",
    "    print(f\"Best parameters: {grid.best_params_}\")\n",
    "    print(f\"Best CV score: {grid.best_score_:.4f}\")\n",
    "    \n",
    "    \n",
    "    evaluate_model(best_model, X_train, y_train, X_test, y_test, task_type='binary' if task == 'binary' else 'multiclass')\n",
    "    \n",
    "    return best_model\n",
    "\n"
