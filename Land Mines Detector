    "# ===================================\n",
    "# PREPROCESSING \n",
    "# ===================================\n",
    "\n",
    "# Mapping delle classi per plotting e interpretazione\n",
    "binary_classes = {0: 'No_Mine', 1: 'Mine'}\n",
    "multiclass_labels_map = {2: 'Anti Tank', 3: 'Anti-Personnel', 4: 'Booby Trapped Anti-Personnel', 5: 'M14 Anti-Personnel'}\n",
    "\n",
    "# === FUNZIONE PER AGGIUNGERE FEATURES ===\n",
    "def add_engineered_features(X):\n",
    "    \"\"\"Aggiunge features ingegnerizzate al dataset\"\"\"\n",
    "    X_aumentato = X.copy()\n",
    "    X_aumentato['VH_interaction'] = X['Voltage'] * X['Height']\n",
    "    X_aumentato['Voltage_squared'] = X['Voltage'] ** 2\n",
    "    X_aumentato['Height_squared'] = X['Height'] ** 2\n",
    "    return X_aumentato\n",
    "\n",
    "# Estrazione delle feature base\n",
    "X = df[['Voltage', 'Height', 'Soil']].copy()\n",
    "\n",
    "# Target per classificazione binaria\n",
    "df['binary_target'] = df['Mine'].apply(lambda x: 0 if x == 1 else 1)\n",
    "\n",
    "# Target per classificazione multiclasse\n",
    "df_multiclass = df.copy()\n",
    "df_multiclass['multiclass_target'] = df['Mine'].where(df['Mine'] != 1)\n",
    "df_multiclass = df_multiclass.dropna(subset=['multiclass_target'])\n",
    "\n",
    "# Variabili target\n",
    "y_binary = df['binary_target']\n",
    "y_multiclass = df_multiclass['multiclass_target']\n",
    "X_multiclass = X.loc[df_multiclass.index]\n",
    "\n",
    "# Split dataset base\n",
    "X_train_binary, X_test_binary, y_train_binary, y_test_binary = train_test_split(\n",
    "    X, y_binary, test_size=0.15, random_state=42, stratify=y_binary\n",
    ")\n",
    "\n",
    "X_train_multiclass, X_test_multiclass, y_train_multiclass, y_test_multiclass = train_test_split(\n",
    "    X_multiclass, y_multiclass, test_size=0.15, random_state=42, stratify=y_multiclass\n",
    ")\n",
    "\n",
    "# ================================\n",
    "# CREAZIONE DEI DATASET SPECIFICI\n",
    "# ================================\n",
    "\n",
    "# ================================================================\n",
    "# 1. KNN DATASET - FEATURES BASE CON STANDARDIZZAZIONE (NO ENCODING)\n",
    "# ================================================================\n",
    "\n",
    "def preprocess_for_knn(X_train, X_test, apply_oversampling=False, y_train=None):\n",
    "    \"\"\"Preprocessing per KNN: solo standardizzazione (senza encoding)\"\"\"\n",
    "    \n",
    "    # Copia dei dataset originali (manteniamo Soil come categorica)\n",
    "    X_train_final = X_train.copy()\n",
    "    X_test_final = X_test.copy()\n",
    "    \n",
    "    # Standardizzazione delle colonne numeriche (Voltage, Height)\n",
    "    numeric_cols = ['Voltage', 'Height']\n",
    "    scaler = StandardScaler()\n",
    "    \n",
    "    X_train_final[numeric_cols] = scaler.fit_transform(X_train[numeric_cols])\n",
    "    X_test_final[numeric_cols] = scaler.transform(X_test[numeric_cols])\n",
    "    \n",
    "    # Oversampling se richiesto\n",
    "    if apply_oversampling and y_train is not None:\n",
    "        # Per KNN con variabili categoriche, usiamo SMOTENC\n",
    "        categorical_indices = [2]  # Indice della colonna 'Soil' (0=Voltage, 1=Height, 2=Soil)\n",
    "        smote = SMOTENC(categorical_features=categorical_indices, random_state=42)\n",
    "        X_train_final, y_train_final = smote.fit_resample(X_train_final, y_train)\n",
    "        return X_train_final, X_test_final, scaler, y_train_final\n",
    "    \n",
    "    return X_train_final, X_test_final, scaler\n",
    "\n",
    "# Binary\n",
    "X_train_knn_basic_binary, X_test_knn_basic_binary, scaler_knn_basic_binary = preprocess_for_knn(\n",
    "    X_train_binary, X_test_binary\n",
    ")\n",
    "y_train_knn_basic_binary = y_train_binary.copy()\n",
    "y_test_knn_basic_binary = y_test_binary.copy()\n",
    "\n",
    "# Multiclass\n",
    "X_train_knn_basic_multiclass, X_test_knn_basic_multiclass, scaler_knn_basic_multiclass = preprocess_for_knn(\n",
    "    X_train_multiclass, X_test_multiclass\n",
    ")\n",
    "y_train_knn_basic_multiclass = y_train_multiclass.copy()\n",
    "y_test_knn_basic_multiclass = y_test_multiclass.copy()\n",
    "\n",
    "# ================================================================\n",
    "# 2. KNN DATASET - CON STANDARDIZZAZIONE E OVERSAMPLING (NO ENCODING)\n",
    "# ================================================================\n",
    "\n",
    "# Binary - con standardizzazione e oversampling\n",
    "X_train_knn_oversampled_binary, X_test_knn_oversampled_binary, scaler_knn_over_binary, y_train_knn_oversampled_binary = preprocess_for_knn(\n",
    "    X_train_binary, X_test_binary, apply_oversampling=True, y_train=y_train_binary\n",
    ")\n",
    "y_test_knn_oversampled_binary = y_test_binary.copy()\n",
    "\n",
    "# Multiclass - con standardizzazione e oversampling\n",
    "X_train_knn_oversampled_multiclass, X_test_knn_oversampled_multiclass, scaler_knn_over_multiclass, y_train_knn_oversampled_multiclass = preprocess_for_knn(\n",
    "    X_train_multiclass, X_test_multiclass, apply_oversampling=True, y_train=y_train_multiclass\n",
    ")\n",
    "y_test_knn_oversampled_multiclass = y_test_multiclass.copy()\n",
    "\n",
    "# ================================================================\n",
    "# 3. ANN DATASET - CON ENCODING E STANDARDIZZAZIONE\n",
    "# ================================================================\n",
    "\n",
    "def preprocess_for_ann(X_train, X_test, add_features=False):\n",
    "    \"\"\"Preprocessing per ANN con encoding e standardizzazione\"\"\"\n",
    "    \n",
    "    # Copia dei dataset\n",
    "    X_train_processed = X_train.copy()\n",
    "    X_test_processed = X_test.copy()\n",
    "    \n",
    "    # Aggiunta features ingegnerizzate se richiesto\n",
    "    if add_features:\n",
    "        X_train_processed = add_engineered_features(X_train_processed)\n",
    "        X_test_processed = add_engineered_features(X_test_processed)\n",
    "        numeric_cols = ['Voltage', 'Height', 'VH_interaction', 'Voltage_squared', 'Height_squared']\n",
    "    else:\n",
    "        numeric_cols = ['Voltage', 'Height']\n",
    "    \n",
    "    # One-hot encoding per la colonna Soil\n",
    "    X_train_encoded = pd.get_dummies(X_train_processed, columns=['Soil'], prefix='Soil', drop_first=True, dtype=int)\n",
    "    X_test_encoded = pd.get_dummies(X_test_processed, columns=['Soil'], prefix='Soil', drop_first=True, dtype=int)\n",
    "    \n",
    "    # Allinea le colonne tra train e test\n",
    "    X_train_encoded, X_test_encoded = X_train_encoded.align(X_test_encoded, join='left', axis=1, fill_value=0)\n",
    "    \n",
    "    # Standardizzazione delle colonne numeriche\n",
    "    scaler = StandardScaler()\n",
    "    X_train_final = X_train_encoded.copy()\n",
    "    X_test_final = X_test_encoded.copy()\n",
    "    \n",
    "    X_train_final[numeric_cols] = scaler.fit_transform(X_train_encoded[numeric_cols])\n",
    "    X_test_final[numeric_cols] = scaler.transform(X_test_encoded[numeric_cols])\n",
    "    \n",
    "    return X_train_final, X_test_final, scaler\n",
    "\n",
    "# Task binaria\n",
    "X_train_ann_basic_binary, X_test_ann_basic_binary, scaler_ann_basic_binary = preprocess_for_ann(\n",
    "    X_train_binary, X_test_binary, add_features=False\n",
    ")\n",
    "y_train_ann_basic_binary = y_train_binary.copy()\n",
    "y_test_ann_basic_binary = y_test_binary.copy()\n",
    "\n",
    "# Task multiclasse\n",
    "X_train_ann_basic_multiclass, X_test_ann_basic_multiclass, scaler_ann_basic_multiclass = preprocess_for_ann(\n",
    "    X_train_multiclass, X_test_multiclass, add_features=False\n",
    ")\n",
    "y_train_ann_basic_multiclass = y_train_multiclass.copy()\n",
    "y_test_ann_basic_multiclass = y_test_multiclass.copy()\n",
    "\n",
    "# ================================================================\n",
    "# 4. ANN DATASET - CON ENCODING, STANDARDIZZAZIONE E FEATURE AGGIUNTE\n",
    "# ================================================================\n",
    "\n",
    "# Task binaria\n",
    "X_train_ann_engineered_binary, X_test_ann_engineered_binary, scaler_ann_eng_binary = preprocess_for_ann(\n",
    "    X_train_binary, X_test_binary, add_features=True\n",
    ")\n",
    "y_train_ann_engineered_binary = y_train_binary.copy()\n",
    "y_test_ann_engineered_binary = y_test_binary.copy()\n",
    "\n",
    "# Task multiclasse\n",
    "X_train_ann_engineered_multiclass, X_test_ann_engineered_multiclass, scaler_ann_eng_multiclass = preprocess_for_ann(\n",
    "    X_train_multiclass, X_test_multiclass, add_features=True\n",
    ")\n",
